# macOS
.DS_Store
._*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# OS / Cloud
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
$RECYCLE.BIN/

# LEAP — user-private files that should never be committed.
# Real user data lives at root-level inputs/ and outputs/ when they
# bootstrap a workspace from templates/outputs_scaffold/.
# templates/ and the canonical examples/maria_silva/ are repo content
# and must NOT be ignored. Other examples/* folders are user-private
# scratchpads and stay local only.
/inputs/
/outputs/
/examples/*
!/examples/maria_silva/

# A user might also keep inputs alongside the repo at this convention:
/my_cv/
/workspace/

# Backup files
*.bak
*.tmp
*~
